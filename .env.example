# Orbitory host-agent environment configuration
# Copy this file to .env and fill in real values for your environment.

# Shared secret that clients must present to pair with this host-agent,
# either as a "token" query param on the ws:// upgrade request
# (ws://host:port/ws?token=...) or as payload.token in the first
# client.hello message sent within 5 seconds of connecting.
#
# In development, if this is left unset, the server falls back to a
# well-known token "orbitory-dev-token" and prints a loud warning on
# startup. Never rely on that fallback in anything but local development
# — always set a real, unique, secret token before exposing this server
# beyond your own machine.
ORBITORY_PAIRING_TOKEN=

# A QR/pairing grant must be used within this many seconds (default: 600).
ORBITORY_PAIRING_TTL_SECONDS=600

# After its first successful saved-profile connection, the credential uses
# this sliding lifetime instead (default: 30 days).
ORBITORY_DEVICE_TOKEN_TTL_SECONDS=2592000

# Port the host-agent HTTP/WebSocket server listens on.
# Defaults to 4000 if unset.
PORT=4000
