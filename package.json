{
  "name": "orbitory-host",
  "type": "module",
  "version": "0.1.9",
  "description": "Local host-agent for Orbitory, the iPhone workroom for AI coding agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Renga154/orbitory-host.git"
  },
  "bugs": {
    "url": "https://github.com/Renga154/orbitory-host/issues"
  },
  "homepage": "https://github.com/Renga154/orbitory-host#readme",
  "bin": {
    "orbitory-host": "bin/orbitory-host.js"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/demo-agent.js",
    "scripts/generate-dev-cert.mjs",
    "scripts/orbitory-approval-bridge.js",
    "scripts/pairing-cli.ts",
    "scripts/prepare-claude-stream-smoke.mjs",
    ".env.example",
    "orbitory.config.example.json",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    ".gitignore",
    "docs/guide/"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build",
    "pack:local": "mkdir -p .orbitory-pack && npm pack --pack-destination .orbitory-pack",
    "prepare:public-repo": "node scripts/prepare-public-host-repo.mjs",
    "pairing:print": "tsx scripts/pairing-cli.ts print",
    "pairing:list": "tsx scripts/pairing-cli.ts list",
    "pairing:revoke": "tsx scripts/pairing-cli.ts revoke",
    "tls:generate": "node scripts/generate-dev-cert.mjs",
    "smoke:claude-stream:prepare": "node scripts/prepare-claude-stream-smoke.mjs",
    "test": "ORBITORY_DEMO_SESSIONS=true ORBITORY_PAIRING_TOKEN=orbitory-test-token ORBITORY_AGENT_CONFIG_PATH=tests/fixtures/test-agents.config.json ORBITORY_CONTAINER_ENGINE_PATH=tests/fixtures/fake-container-engine.js ORBITORY_AUDIT_LOG_PATH=/dev/null ORBITORY_HELLO_TIMEOUT_MS=1500 node --import tsx --test --test-concurrency=1 tests/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "bonjour-service": "^1.4.2",
    "fastify": "^5.2.1",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
